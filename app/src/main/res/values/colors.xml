<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Terminal base -->
    <color name="terminal_bg">#050810</color>
    <color name="terminal_bg_card">#040A14</color>
    <color name="terminal_bg_card_active">#061828</color>
    <color name="terminal_bg_section">#04080F</color>

    <!-- Terminal accent: xanh dương nhạt -->
    <color name="terminal_cyan">#00E5FF</color>
    <color name="terminal_cyan_dark">#00B4D8</color>
    <color name="terminal_cyan_dim">#004D60</color>
    <color name="terminal_border">#00B4D8</color>
    <color name="terminal_border_dim">#0A2030</color>

    <!-- Text -->
    <color name="terminal_white">#E0E8F0</color>
    <color name="terminal_secondary">#7A9BB5</color>
    <color name="terminal_tertiary">#2A4A5E</color>
    <color name="terminal_green">#00FF88</color>
    <color name="terminal_yellow">#FFD700</color>
    <color name="terminal_red">#FF4444</color>
    <color name="terminal_orange">#FF8800</color>

    <!-- Status -->
    <color name="status_online">#00FF88</color>
    <color name="status_offline">#2A4A5E</color>

    <!-- Switch -->
    <color name="switch_track_off">#0A1520</color>
    <color name="switch_thumb">#00E5FF</color>

    <!-- Island / notification -->
    <color name="island_bg">#05101A</color>

    <!-- ASCII art 7 màu cầu vồng -->
    <color name="ascii_r1">#FF2200</color>
    <color name="ascii_r2">#FF8800</color>
    <color name="ascii_r3">#FFE000</color>
    <color name="ascii_r4">#00FF44</color>
    <color name="ascii_r5">#00CCFF</color>
    <color name="ascii_r6">#4466FF</color>
    <color name="ascii_r7">#BB22FF</color>

    <!-- Legacy aliases (các drawable cũ tham chiếu) -->
    <color name="bg_root">@color/terminal_bg</color>
    <color name="bg_card">@color/terminal_bg_card</color>
    <color name="bg_card_alt">@color/terminal_bg_card_active</color>
    <color name="bg_card_stroke">@color/terminal_border_dim</color>
    <color name="accent_primary">@color/terminal_cyan</color>
    <color name="accent_primary_dark">@color/terminal_cyan_dark</color>
    <color name="accent_primary_light">@color/terminal_cyan</color>
    <color name="accent_secondary">@color/terminal_cyan_dark</color>
    <color name="text_primary">@color/terminal_white</color>
    <color name="text_secondary">@color/terminal_secondary</color>
    <color name="text_tertiary">@color/terminal_tertiary</color>
    <color name="danger">@color/terminal_red</color>
    <color name="divider">@color/terminal_border_dim</color>
</resources>
