<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/terminal_cyan_dim" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/terminal_cyan_dark" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/switch_track_off" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/terminal_border_dim" />
        </shape>
    </item>
</selector>
