<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#0A1A28" />
            <stroke android:width="1dp" android:color="@color/terminal_border" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/terminal_bg_card" />
            <stroke android:width="1dp" android:color="@color/terminal_border_dim" />
        </shape>
    </item>
</selector>
