<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        android:overScrollMode="always">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View android:id="@+id/statusBarSpacer"
                android:layout_width="match_parent" android:layout_height="0dp"/>

            <!-- Page header -->
            <LinearLayout
                android:id="@+id/pageHeader"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp" android:paddingEnd="24dp"
                android:paddingTop="20dp" android:paddingBottom="18dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/device_page_title" android:textColor="@color/terminal_white"
                    android:textSize="26sp" android:textStyle="bold" android:letterSpacing="-0.01"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="@string/device_page_subtitle"
                    android:textColor="@color/terminal_secondary" android:textSize="13.5sp"/>
            </LinearLayout>

            <!-- ASCII logo card -->
            <LinearLayout
                android:id="@+id/cardAsciiLogo"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:background="@drawable/bg_home_card" android:elevation="2dp"
                android:gravity="center" android:padding="18dp">

                <TextView android:id="@+id/tvAsciiArt"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:fontFamily="monospace" android:textSize="7.5sp"
                    android:lineSpacingMultiplier="1.05" android:textScaleX="0.95"
                    tools:text="ASCII ART"/>
            </LinearLayout>

            <!-- Device info card (chi tiết) -->
            <LinearLayout
                android:id="@+id/cardDeviceInfo"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="14dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:background="@drawable/bg_home_card" android:elevation="2dp"
                android:orientation="vertical" android:padding="18dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp" android:text="@string/device_info_title"
                    android:textColor="@color/terminal_white" android:textSize="15sp" android:textStyle="bold"/>

                <include layout="@layout/row_device_info" android:id="@+id/rowModel"/>
                <include layout="@layout/row_device_info" android:id="@+id/rowAndroid"/>
                <include layout="@layout/row_device_info" android:id="@+id/rowChip"/>
                <include layout="@layout/row_device_info" android:id="@+id/rowVulkan"/>
                <include layout="@layout/row_device_info" android:id="@+id/rowRam"/>
                <include layout="@layout/row_device_info" android:id="@+id/rowScreen"/>
                <include layout="@layout/row_device_info" android:id="@+id/rowBattery"/>
                <include layout="@layout/row_device_info" android:id="@+id/rowIp"/>
                <include layout="@layout/row_device_info" android:id="@+id/rowDate"/>
            </LinearLayout>

            <!-- Shizuku status card -->
            <LinearLayout
                android:id="@+id/cardShizuku"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="14dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:background="@drawable/bg_home_card" android:elevation="2dp"
                android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">

                <View android:id="@+id/dotShizukuStatus"
                    android:layout_width="10dp" android:layout_height="10dp"
                    android:background="@drawable/dot_status_off"/>

                <TextView android:id="@+id/tvShizukuStatus"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:textColor="@color/terminal_white" android:textSize="14sp" android:textStyle="bold"
                    android:text="@string/shizuku_disconnected"/>

                <TextView android:id="@+id/tvShizukuHint"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="@drawable/bg_lock_banner" android:paddingStart="10dp"
                    android:paddingEnd="10dp" android:paddingTop="4dp" android:paddingBottom="4dp"
                    android:text="GRANT" android:textColor="@color/lock_badge_text"
                    android:textSize="10sp" android:textStyle="bold" android:visibility="gone"/>
            </LinearLayout>

            <!-- Lock banner -->
            <LinearLayout
                android:id="@+id/lockBanner"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="14dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:background="@drawable/bg_lock_banner" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/lock_banner_title" android:textColor="@color/lock_badge_text"
                    android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" android:text="@string/lock_banner_desc"
                    android:textColor="@color/terminal_secondary" android:textSize="12.5sp" android:lineSpacingExtra="2dp"/>
            </LinearLayout>

            <!-- Section: Optimization tools -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="26dp" android:layout_marginStart="20dp"
                android:text="@string/section_tools_title" android:textColor="@color/terminal_white"
                android:textSize="17sp" android:textStyle="bold"/>

            <!-- G-BOOST+ -->
            <LinearLayout
                android:id="@+id/cardGBoost"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="10dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:background="@drawable/bg_terminal_row" android:elevation="1dp"
                android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">

                <FrameLayout android:layout_width="46dp" android:layout_height="46dp"
                    android:background="@drawable/bg_feature_icon">
                    <ImageView android:layout_width="23dp" android:layout_height="23dp"
                        android:layout_gravity="center" android:src="@drawable/ic_bolt" android:contentDescription="@null"/>
                </FrameLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="14dp" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/gboost_title" android:textColor="@color/terminal_white"
                        android:textSize="15.5sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvGBoostSubtitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp" android:text="@string/gboost_subtitle"
                        android:textColor="@color/terminal_secondary" android:textSize="12sp"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchGBoost"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:enabled="false"
                    app:thumbTint="@color/switch_thumb_color" app:track="@drawable/switch_track"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/boxGBoostLog"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:background="@drawable/bg_log_box" android:padding="12dp" android:visibility="gone">
                <TextView android:id="@+id/tvGBoostLog"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:fontFamily="monospace" android:textColor="@color/terminal_cyan"
                    android:textSize="11sp" tools:text="[1/50] Xoá hoạt ảnh..."/>
            </LinearLayout>

            <!-- SUPPORT NEW² -->
            <LinearLayout
                android:id="@+id/cardSupport"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="10dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:background="@drawable/bg_terminal_row" android:elevation="1dp"
                android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">

                <FrameLayout android:layout_width="46dp" android:layout_height="46dp"
                    android:background="@drawable/bg_feature_icon_purple">
                    <ImageView android:layout_width="23dp" android:layout_height="23dp"
                        android:layout_gravity="center" android:src="@drawable/ic_display" android:contentDescription="@null"/>
                </FrameLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="14dp" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/support_title" android:textColor="@color/terminal_white"
                        android:textSize="15.5sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvSupportSubtitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp" android:text="@string/support_subtitle"
                        android:textColor="@color/terminal_secondary" android:textSize="12sp"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchSupport"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:enabled="false"
                    app:thumbTint="@color/switch_thumb_color" app:track="@drawable/switch_track"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/boxResolutionInfo"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:background="@drawable/bg_log_box" android:padding="12dp" android:visibility="gone">
                <TextView android:id="@+id/tvResolutionDetail"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:fontFamily="monospace" android:textColor="@color/terminal_secondary" android:textSize="11sp"/>
            </LinearLayout>

            <ProgressBar android:id="@+id/progressRunning"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="3dp"
                android:layout_marginTop="10dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:indeterminate="true" android:indeterminateTint="@color/terminal_cyan" android:visibility="gone"/>

            <!-- Rocket: chạy script tối ưu -->
            <LinearLayout
                android:id="@+id/cardRocket"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="14dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:background="@drawable/bg_rocket_card" android:elevation="3dp"
                android:gravity="center_vertical" android:orientation="horizontal" android:padding="18dp">

                <FrameLayout android:layout_width="48dp" android:layout_height="48dp"
                    android:background="@drawable/bg_rocket_icon_chip">
                    <ImageView android:layout_width="26dp" android:layout_height="26dp"
                        android:layout_gravity="center" android:src="@drawable/ic_rocket" android:contentDescription="@null"/>
                </FrameLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="14dp" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/rocket_title" android:textColor="#FFFFFF"
                        android:textSize="15.5sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp" android:text="@string/rocket_subtitle"
                        android:textColor="#D8E4FF" android:textSize="12sp"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="→" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Section: System -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="26dp" android:layout_marginStart="20dp"
                android:text="@string/section_system_title" android:textColor="@color/terminal_white"
                android:textSize="17sp" android:textStyle="bold"/>

            <LinearLayout android:id="@+id/btnFactoryReset"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="10dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:background="@drawable/bg_terminal_row" android:elevation="1dp"
                android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_feature_icon_orange">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:layout_gravity="center" android:src="@drawable/ic_refresh" android:contentDescription="@null"/>
                </FrameLayout>

                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="14dp"
                    android:text="@string/factory_reset" android:textColor="@color/terminal_white"
                    android:textSize="14.5sp" android:textStyle="bold"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textColor="@color/terminal_tertiary" android:textSize="20sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnLogout"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="10dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:background="@drawable/bg_terminal_row" android:elevation="1dp"
                android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_feature_icon">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:layout_gravity="center" android:src="@drawable/ic_logout" android:contentDescription="@null"/>
                </FrameLayout>

                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="14dp"
                    android:text="@string/logout" android:textColor="@color/terminal_red"
                    android:textSize="14.5sp" android:textStyle="bold"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textColor="@color/terminal_tertiary" android:textSize="20sp"/>
            </LinearLayout>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="24dp" android:layout_marginBottom="16dp"
                android:gravity="center" android:text="@string/footer_tag"
                android:textColor="@color/terminal_secondary" android:textSize="11sp" android:alpha="0.6"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
