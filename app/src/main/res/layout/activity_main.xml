<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- STATUS BAR SPACER: dynamic height set by insets in code -->
            <View
                android:id="@+id/statusBarSpacer"
                android:layout_width="match_parent"
                android:layout_height="0dp" />

            <!-- HEADER BLOCK -->
            <LinearLayout
                android:id="@+id/headerInner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="4dp">

                <!-- ASCII ART BOX: "TNhan" 7-màu cầu vồng -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_terminal_box"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/tvAsciiArt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textSize="7.5sp"
                        android:lineSpacingMultiplier="1.05"
                        android:textScaleX="0.95"
                        tools:text="ASCII ART" />
                </LinearLayout>

                <!-- DEVICE INFO BOX -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_terminal_box"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvDeviceInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/terminal_cyan"
                        android:textSize="12sp"
                        tools:text="► Model     : Loading..." />
                </LinearLayout>

            </LinearLayout>

            <!-- SHIZUKU STATUS ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_terminal_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="11dp"
                android:paddingBottom="11dp">

                <View
                    android:id="@+id/dotShizukuStatus"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:background="@drawable/dot_status_off" />

                <TextView
                    android:id="@+id/tvShizukuStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/terminal_white"
                    android:textSize="13sp"
                    android:text="@string/shizuku_disconnected" />

                <TextView
                    android:id="@+id/tvShizukuHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/terminal_red"
                    android:textSize="11sp"
                    android:text="[GRANT]"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ════ SECTION: PERFORMANCE TOOLS ════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_terminal_section"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="18dp"
                    android:background="@color/terminal_cyan" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="monospace"
                    android:text="⚡  PERFORMANCE TOOLS"
                    android:textColor="@color/terminal_cyan"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- CARD: G-BOOST+ -->
            <LinearLayout
                android:id="@+id/cardGBoost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_terminal_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="[1.0]  G-BOOST+"
                        android:textColor="@color/terminal_white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvGBoostSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:text="@string/gboost_subtitle"
                        android:textColor="@color/terminal_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchGBoost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/switch_thumb_color"
                    app:track="@drawable/switch_track" />
            </LinearLayout>

            <!-- LOG BOX G-BOOST -->
            <LinearLayout
                android:id="@+id/boxGBoostLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_log_box"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvGBoostLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/terminal_cyan"
                    android:textSize="11sp"
                    tools:text="[1/50] Xoá hoạt ảnh hệ thống..." />
            </LinearLayout>

            <!-- CARD: SUPPORT NEW² -->
            <LinearLayout
                android:id="@+id/cardSupport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_terminal_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="[1.1]  SUPPORT NEW²"
                        android:textColor="@color/terminal_white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSupportSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:text="@string/support_subtitle"
                        android:textColor="@color/terminal_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchSupport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/switch_thumb_color"
                    app:track="@drawable/switch_track" />
            </LinearLayout>

            <!-- RESOLUTION INFO BOX -->
            <LinearLayout
                android:id="@+id/boxResolutionInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_log_box"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvResolutionDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/terminal_secondary"
                    android:textSize="11sp"
                    tools:text="720x1480 → 1319x2713 dpi 420" />
            </LinearLayout>

            <!-- PROGRESS BAR -->
            <ProgressBar
                android:id="@+id/progressRunning"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="6dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/terminal_cyan"
                android:visibility="gone" />

            <!-- ════ SECTION: SYSTEM ════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_terminal_section"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="18dp"
                    android:background="@color/terminal_yellow" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="monospace"
                    android:text="⚙   SYSTEM"
                    android:textColor="@color/terminal_yellow"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- BTN: FACTORY RESET -->
            <LinearLayout
                android:id="@+id/btnFactoryReset"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="2dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_terminal_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="[2.0]"
                    android:textColor="@color/terminal_yellow"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="monospace"
                    android:text="@string/factory_reset"
                    android:textColor="@color/terminal_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- BTN: LOGOUT -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="2dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_terminal_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="[2.1]"
                    android:textColor="@color/terminal_red"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="monospace"
                    android:text="@string/logout"
                    android:textColor="@color/terminal_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- FOOTER -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="20dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/footer_tag"
                android:textColor="@color/terminal_tertiary"
                android:textSize="11sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
